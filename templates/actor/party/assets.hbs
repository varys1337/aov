<section class="party tab assets {{tab.cssClass}}" data-group="primary" data-tab="assets">
  {{#if partyCompactView}}
    <div class="party-compact-sections party-compact-assets-columns" aria-label="{{localize 'AOV.Party.CompactAssets'}}">
      <section class="party-compact-section">
        <h3>{{localize "AOV.Party.SharedEquipment"}}</h3>
        <div class="party-compact-grid party-compact-assets">
          {{#each assets.weapons as |item|}}
            <article class="party-compact-tile item" data-item-id="{{item.id}}" data-document-class="Item" data-drag="true" data-tooltip="{{item.name}}">
              <img src="{{item.img}}" data-action="viewDoc" alt="{{item.name}}">
            </article>
          {{/each}}
          {{#each assets.armours as |item|}}
            <article class="party-compact-tile item" data-item-id="{{item.id}}" data-document-class="Item" data-drag="true" data-tooltip="{{item.name}}">
              <img src="{{item.img}}" data-action="viewDoc" alt="{{item.name}}">
            </article>
          {{/each}}
          {{#each assets.gear as |item|}}
            <article class="party-compact-tile item" data-item-id="{{item.id}}" data-document-class="Item" data-drag="true" data-tooltip="{{item.name}}">
              <img src="{{item.img}}" data-action="viewDoc" alt="{{item.name}}">
            </article>
          {{/each}}
        </div>
      </section>

      <section class="party-compact-section">
        <h3>{{localize "AOV.Party.Ships"}}</h3>
        {{#if assets.ships.length}}
          <div class="party-compact-grid party-compact-assets">
            {{#each assets.ships as |ship|}}
              <article class="party-compact-tile {{#unless ship.valid}}party-invalid{{/unless}}" data-uuid="{{ship.uuid}}" data-tooltip="{{ship.name}}">
                {{#if ship.valid}}<img src="{{ship.img}}" data-action="viewPartyDocument" data-uuid="{{ship.uuid}}" alt="{{ship.name}}">{{else}}<img src="{{ship.img}}" alt="{{ship.name}}">{{/if}}
                {{#if @root.isGM}}
                  <a class="party-compact-unlink" data-action="removePartyShip" data-uuid="{{ship.uuid}}" data-tooltip="{{localize 'AOV.Party.UnlinkShip'}}"><i class="fas fa-link-slash"></i></a>
                {{/if}}
              </article>
            {{/each}}
          </div>
        {{else}}
          <p class="party-empty">{{localize "AOV.Party.EmptyShips"}}</p>
        {{/if}}
      </section>

      <section class="party-compact-section">
        <h3>{{localize "AOV.Party.Farms"}}</h3>
        {{#if assets.farms.length}}
          <div class="party-compact-grid party-compact-assets">
            {{#each assets.farms as |farm|}}
              <article class="party-compact-tile {{#unless farm.valid}}party-invalid{{/unless}}" data-uuid="{{farm.uuid}}" data-tooltip="{{farm.name}}">
                {{#if farm.valid}}<img src="{{farm.img}}" data-action="viewPartyDocument" data-uuid="{{farm.uuid}}" alt="{{farm.name}}">{{else}}<img src="{{farm.img}}" alt="{{farm.name}}">{{/if}}
                {{#if @root.isGM}}
                  <a class="party-compact-unlink" data-action="removePartyFarm" data-uuid="{{farm.uuid}}" data-tooltip="{{localize 'AOV.Party.UnlinkFarm'}}"><i class="fas fa-link-slash"></i></a>
                {{/if}}
              </article>
            {{/each}}
          </div>
        {{else}}
          <p class="party-empty">{{localize "AOV.Party.EmptyFarms"}}</p>
        {{/if}}
      </section>
    </div>
  {{else}}
  <div class="party-assets-grid">
    <section class="party-asset-section party-equipment-section party-asset-scroll-panel">
      <h3>{{localize "AOV.Party.SharedEquipment"}}</h3>
      <div class="party-asset-scroll-body">
        <ol class="party-equipment-list">
        <li class="item gear-header primBackCol party-weapon-row">
          <div class="left">{{localize "AOV.Party.Weapons"}}</div>
          <div class="centre">{{localize "AOV.damageAbbr"}}</div>
          <div class="centre">{{localize "AOV.damageType"}}</div>
          <div class="centre">{{localize "AOV.hpAbbr"}}</div>
          <div class="centre">{{localize "AOV.encumbranceAbbr"}}</div>
          <div class="centre">{{localize "AOV.quantityAbbr"}}</div>
          <div class="centre">
            {{#if @root.editable}}
              <a data-action="createDoc" data-document-class="Item" data-type="weapon" data-tooltip="{{localize 'AOV.createDoc' type=(localize 'TYPES.Item.weapon')}}">
                <i class="fas fa-plus"></i>
              </a>
            {{/if}}
          </div>
        </li>
        {{#each assets.weapons as |item|}}
          <li class="item party-weapon-row" data-item-id="{{item.id}}" data-drag="true" data-document-class="Item">
            <div class="gear-name left rollable" data-action="viewDoc">{{item.name}}</div>
            <div class="gear-name centre">{{item.damage}}</div>
            <div class="gear-name centre truncate">{{item.damageType}}</div>
            <div class="gear-name centre">{{item.hp.value}}/{{item.hp.max}}</div>
            <div class="gear-name centre">{{item.enc}}</div>
            <div class="gear-name centre"><input class="gear-input party-item-quantity" type="number" value="{{item.quantity}}"></div>
            <div class="gear-controls centre">
              <a data-action="deleteDoc" data-tooltip="{{localize 'AOV.deleteDoc' type=(localize 'TYPES.Item.weapon')}}"><i class="fas fa-trash"></i></a>
            </div>
          </li>
        {{else}}
          <li class="party-empty">{{localize "AOV.Party.EmptyWeapons"}}</li>
        {{/each}}

        <li class="item gear-header secBackCol party-armour-row">
          <div class="left">{{localize "AOV.Party.Armour"}}</div>
          <div class="centre">{{localize "AOV.hitLocations"}}</div>
          <div class="centre">{{localize "AOV.armourPointsAbbr"}}</div>
          <div class="centre">{{localize "AOV.encumbranceAbbr"}}</div>
          <div class="centre">{{localize "AOV.quantityAbbr"}}</div>
          <div class="centre">
            {{#if @root.editable}}
              <a data-action="createDoc" data-document-class="Item" data-type="armour" data-tooltip="{{localize 'AOV.createDoc' type=(localize 'TYPES.Item.armour')}}">
                <i class="fas fa-plus"></i>
              </a>
            {{/if}}
          </div>
        </li>
        {{#each assets.armours as |item|}}
          <li class="item party-armour-row" data-item-id="{{item.id}}" data-drag="true" data-document-class="Item">
            <div class="gear-name left rollable" data-action="viewDoc">{{item.name}}</div>
            <div class="gear-name centre">{{item.locations}}</div>
            <div class="gear-name centre">{{item.ap}}</div>
            <div class="gear-name centre">{{item.enc}}</div>
            <div class="gear-name centre"><input class="gear-input party-item-quantity" type="number" value="{{item.quantity}}"></div>
            <div class="gear-controls centre">
              <a data-action="deleteDoc" data-tooltip="{{localize 'AOV.deleteDoc' type=(localize 'TYPES.Item.armour')}}"><i class="fas fa-trash"></i></a>
            </div>
          </li>
        {{else}}
          <li class="party-empty">{{localize "AOV.Party.EmptyArmour"}}</li>
        {{/each}}

        <li class="item gear-header terBackCol party-gear-row">
          <div class="left">{{localize "AOV.Party.Gear"}}</div>
          <div class="centre">{{localize "AOV.encumbranceAbbr"}}</div>
          <div class="centre">{{localize "AOV.quantityAbbr"}}</div>
          <div class="centre">{{localize "AOV.value"}}</div>
          <div class="centre">
            {{#if @root.editable}}
              <a data-action="createDoc" data-document-class="Item" data-type="gear" data-tooltip="{{localize 'AOV.createDoc' type=(localize 'TYPES.Item.gear')}}">
                <i class="fas fa-plus"></i>
              </a>
            {{/if}}
          </div>
        </li>
        {{#each assets.gear as |item|}}
          <li class="item party-gear-row" data-item-id="{{item.id}}" data-drag="true" data-document-class="Item">
            <div class="gear-name left rollable" data-action="viewDoc">{{item.name}}</div>
            <div class="gear-name centre">{{item.enc}}</div>
            <div class="gear-name centre"><input class="gear-input party-item-quantity" type="number" value="{{item.quantity}}"></div>
            <div class="gear-name centre">{{item.value}}</div>
            <div class="gear-controls centre">
              <a data-action="deleteDoc" data-tooltip="{{localize 'AOV.deleteDoc' type=(localize 'TYPES.Item.gear')}}"><i class="fas fa-trash"></i></a>
            </div>
          </li>
        {{else}}
          <li class="party-empty">{{localize "AOV.Party.EmptyEquipment"}}</li>
        {{/each}}
        </ol>
      </div>
    </section>

    <aside class="party-asset-sidebar">
      <section class="party-asset-section party-asset-scroll-panel">
        <h3>{{localize "AOV.Party.Ships"}}</h3>
        <div class="party-asset-scroll-body">
          {{#each assets.ships as |ship|}}
          <article class="party-linked-card {{#unless ship.valid}}party-invalid{{/unless}}" data-uuid="{{ship.uuid}}">
            {{#if ship.valid}}<img src="{{ship.img}}" data-action="viewPartyDocument" data-uuid="{{ship.uuid}}">{{else}}<img src="{{ship.img}}">{{/if}}
            <div>
              <div class="party-card-title">
                {{#if ship.valid}}<a class="rollable" data-action="viewPartyDocument" data-uuid="{{ship.uuid}}">{{ship.name}}</a>{{else}}<span>{{ship.name}}</span>{{/if}}
                {{#if @root.isGM}}
                  <a data-action="removePartyShip" data-uuid="{{ship.uuid}}" data-tooltip="{{localize 'AOV.Party.UnlinkShip'}}"><i class="fas fa-link-slash"></i></a>
                {{/if}}
              </div>
              {{#if ship.valid}}
                <div class="party-linked-stats">
                  <span>{{ship.shipType}} {{ship.hullType}}</span>
                  <span>{{localize "AOV.ship.hullQualityAbbr"}} {{ship.hullQuality}}</span>
                  <span>{{localize "AOV.ship.seaWorthyAbbr"}} {{ship.seaworthy.value}}/{{ship.seaworthy.max}}</span>
                  <span>{{localize "AOV.ship.structuralPointsAbbr"}} {{ship.sp.value}}/{{ship.sp.max}}</span>
                  <span>{{localize "AOV.ship.capacityAbbr"}} {{ship.cargo}}</span>
                  <span>{{localize "AOV.windSpeed"}} {{ship.wind}}</span>
                  <span>{{localize "AOV.ship.captain"}} {{ship.captain}}</span>
                  <span>{{localize "AOV.ship.helmsman"}} {{ship.helmsman}}</span>
                  <span>{{localize "AOV.ship.boatShip"}} {{ship.boat}}</span>
                  <span>{{localize "AOV.ship.navigate"}} {{ship.navigate}}</span>
                </div>
                <div class="party-crew-grid">
                  {{#each ship.crew as |crew|}}
                    <span>{{crew.label}} {{crew.value}}/{{crew.min}}</span>
                  {{/each}}
                </div>
              {{else}}
                <p class="party-empty">{{localize "AOV.Party.InvalidReference"}}</p>
              {{/if}}
            </div>
          </article>
          {{else}}
            <p class="party-empty">{{localize "AOV.Party.EmptyShips"}}</p>
          {{/each}}
        </div>
      </section>

      <section class="party-asset-section party-asset-scroll-panel">
        <h3>{{localize "AOV.Party.Farms"}}</h3>
        <div class="party-asset-scroll-body">
          {{#each assets.farms as |farm|}}
          <article class="party-linked-card {{#unless farm.valid}}party-invalid{{/unless}}" data-uuid="{{farm.uuid}}">
            {{#if farm.valid}}<img src="{{farm.img}}" data-action="viewPartyDocument" data-uuid="{{farm.uuid}}">{{else}}<img src="{{farm.img}}">{{/if}}
            <div>
              <div class="party-card-title">
                {{#if farm.valid}}<a class="rollable" data-action="viewPartyDocument" data-uuid="{{farm.uuid}}">{{farm.name}}</a>{{else}}<span>{{farm.name}}</span>{{/if}}
                {{#if @root.isGM}}
                  <a data-action="removePartyFarm" data-uuid="{{farm.uuid}}" data-tooltip="{{localize 'AOV.Party.UnlinkFarm'}}"><i class="fas fa-link-slash"></i></a>
                {{/if}}
              </div>
              {{#if farm.valid}}
                <div class="party-linked-stats">
                  <span>{{localize "AOV.farmType"}} {{farm.farmType}}</span>
                  <span>{{localize "AOV.size"}} {{farm.size}}</span>
                  <span>{{localize "AOV.status"}} {{farm.status}}</span>
                  <span>{{localize "AOV.value"}} {{farm.value}}</span>
                  <span>{{localize "AOV.cattle"}} {{farm.cattle}}</span>
                  <span>{{localize "AOV.sheep"}} {{farm.sheep}}</span>
                  <span>{{localize "AOV.horses"}} {{farm.horses}}</span>
                </div>
              {{else}}
                <p class="party-empty">{{localize "AOV.Party.InvalidReference"}}</p>
              {{/if}}
            </div>
          </article>
          {{else}}
            <p class="party-empty">{{localize "AOV.Party.EmptyFarms"}}</p>
          {{/each}}
        </div>
      </section>
    </aside>
  </div>
  {{/if}}
</section>
